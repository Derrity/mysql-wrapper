prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: MySQLWrapper
Description: C++23 MySQL wrapper with modules, RAII, expected errors, and pooled async execution
Version: @PROJECT_VERSION@
Requires: mysqlclient
Libs: -L${libdir} -lmysqlwrapper
Cflags: -I${includedir}
